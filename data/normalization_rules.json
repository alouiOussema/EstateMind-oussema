{
  "price": {
    "remove": [
      "TND",
      "DT",
      "dinars",
      "dinar",
      "€",
      "$"
    ],
    "thousands_sep": [
      " ",
      ","
    ],
    "decimal_sep": ".",
    "min": 500,
    "max": 50000000,
    "output_type": "float"
  },
  "surface": {
    "remove": [
      "m²",
      "m2",
      "mètres",
      "metres",
      "m"
    ],
    "decimal_sep": ".",
    "min": 10,
    "max": 10000,
    "output_type": "float"
  },
  "rooms": {
    "patterns": [
      {
        "regex": "S\\s*\\+\\s*(\\d+)",
        "add": 1
      },
      {
        "regex": "(\\d+)\\s*chambres?"
      },
      {
        "regex": "(\\d+)\\s*pi[eè]ces?"
      },
      {
        "regex": "studio",
        "value": 1
      },
      {
        "regex": "F(\\d+)",
        "extract": 1
      },
      {
        "regex": "T(\\d+)",
        "extract": 1
      }
    ],
    "min": 1,
    "max": 20,
    "output_type": "int"
  },
  "city": {
    "split": [
      "|",
      ","
    ],
    "take_first": true,
    "title_case": true,
    "output_type": "string"
  },
  "governorate": {
